# 微信 iLink / OpenClaw
# 留空会使用默认: https://ilinkai.weixin.qq.com
ILINK_BASE_URL=

# ---------- 调用 Cursor agent（选一种模式）----------

# simple：自定义 HTTP，POST JSON { userId, text, meta?, systemPrompt? }，响应 { reply }
# openai_compat：OpenAI /v1/chat/completions（如 cursor-agent-api-proxy，默认端口 4646）
CURSOR_AGENT_MODE=simple

# simple 模式：插件提供的完整 URL
CURSOR_AGENT_URL=http://127.0.0.1:31800/agent/chat

# openai_compat 示例（需本机先运行 cursor-agent-api-proxy）:
# CURSOR_AGENT_MODE=openai_compat
# CURSOR_AGENT_URL=http://127.0.0.1:4646/v1
# CURSOR_AGENT_API_KEY=not-needed
# CURSOR_OPENAI_MODEL=auto

# cursor_cli 模式：直接调用本机 Cursor CLI（最稳）。如果 PATH 找不到 agent，可指定绝对路径（Windows 示例）
# CURSOR_AGENT_MODE=cursor_cli
# CURSOR_CLI_MODEL=auto
# CURSOR_CLI_PATH=C:\\Users\\admin\\AppData\\Local\\cursor-agent\\agent.cmd

# 可选：额外请求头 JSON，如 {"X-Api-Key":"..."}
# CURSOR_AGENT_HEADERS=

# 可选：给 agent 的系统提示词
CURSOR_SYSTEM_PROMPT=你是 Cursor 的编码助手，优先给出可执行的解决方案与代码修改建议。

# 超时（毫秒）
CURSOR_AGENT_TIMEOUT_MS=none

# 仅 cursor_cli：子进程 kill 超时。不写则沿用 CURSOR_AGENT_TIMEOUT_MS；0 / none = 等到 agent 自己结束（适合超长任务）
# CURSOR_CLI_TIMEOUT_MS=0

# cursor_cli：执行过程中心跳间隔（毫秒），向微信发进度；0 / off 关闭。默认 10000
# CURSOR_CLI_HEARTBEAT_MS=10000
# 进度文案，{duration} 为中文时长
# WECHAT_CLI_PROGRESS_TEMPLATE=任务执行中，已耗时 {duration}…
# 超时/异常退出且无完整结果时的回复（支持占位符 {reason} {code}，会把具体原因发给微信）
# WECHAT_CLI_ABORT_TEMPLATE=任务中断，请重试。\n\n原因：{reason}

# 其它报错（如 agent 返回错误、网络失败等）发微信的模板，{message} 为错误摘要
# WECHAT_ERROR_TEMPLATE=Cursor Agent 执行报错：\n{message}
# 发到微信的错误信息最大字符数（防过长）
# WECHAT_ERROR_MAX_CHARS=3500

# 回复美化：把 Markdown 转成带图标/分隔线的纯文本（iLink 仅支持纯文本）。0 / off / plain 关闭
# WECHAT_FORMAT_REPLY=1
# 美化里「注意/总结/步骤」等行首关键词加图标，0 关闭
# WECHAT_FORMAT_KEYWORDS=1
# 单条微信最大字符，超出会拆成多条（带【2/3】序号）
# WECHAT_MAX_CHARS_PER_MESSAGE=3500

# cursor_cli 模式下，收到用户消息后先回一条（再发 agent 完整回复）；留空默认「收到。」
# WECHAT_ACK_MESSAGE=收到。
